              "step": 0.01,
              "unit": "%"
            },
            {
              "key": "bias",
              "label": "Bias",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.5,
              "step": 0.01,
              "unit": "%"
            },
            {
              "key": "tone",
              "label": "Tone",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.5,
              "step": 0.01,
              "unit": "%"
            },
            {
              "key": "speed",
              "label": "Speed",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.5,
              "step": 0.01,
              "unit": "%"
