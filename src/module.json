{
  "id": "chowtape",
  "name": "CHOWTape",
  "abbrev": "CT",
  "version": "0.1.0",
  "description": "Analog tape model with Jiles-Atherton hysteresis",
  "author": "charlesvestal",
  "license": "GPL-3.0",
  "dsp": "chowtape.so",
  "api_version": 2,
